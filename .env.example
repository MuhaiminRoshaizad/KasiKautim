# JomSplit env vars.
# Copy this file to .env.local and fill in the values. Never commit .env.local.

# --- Supabase ----------------------------------------------------------------

# Project URL: Supabase Dashboard > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key: Settings > API > anon/public.
# Designed to be public; gated by RLS. Safe in the browser bundle.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key: Settings > API > service_role.
# BYPASSES RLS. Server-only. Never expose to the client.
# Currently used only by elevated server actions (none in D1).
SUPABASE_SERVICE_ROLE_KEY=

# --- Site --------------------------------------------------------------------

# Public site URL used for magic-link redirects and OG image URLs.
# Local dev: http://localhost:3000
# Vercel: set per-environment (preview vs production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI receipt scanner (D3+) ------------------------------------------------

# Google AI Studio key: https://aistudio.google.com/apikey
# Free tier: 15 req/min, 1500 req/day on gemini-2.0-flash. No credit card.
# Used server-side only for receipt scanning.
GOOGLE_GENERATIVE_AI_API_KEY=
